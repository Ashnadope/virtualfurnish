# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Service-role key — used only by the ML recommender script (never exposed to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe Configuration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# OpenAI Configuration
OPENAI_API_KEY=sk-your-api-key-here

# J&T Express Philippines API
# Get these from https://open.jtexpress.ph after developer verification
JT_API_ACCOUNT=your-jt-api-account
JT_API_KEY=your-jt-api-key
# Use demo URL for testing, remove for production
JT_API_BASE_URL=https://demoopenapi.jtexpress.ph/webopenplatformapi
